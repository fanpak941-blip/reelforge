# --- Free-tier keys only. Get these for $0 before paid scale-up. ---

# Script generation — Groq free tier (fast Llama models, generous free quota)
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Stock visuals — Pexels (100% free, no card required)
# Sign up: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# Server port (Render sets this automatically — you usually don't need to touch it)
PORT=4000

# --- NOT needed for the free MVP — only add when you have paying customers ---
# ELEVENLABS_API_KEY=
# HEYGEN_API_KEY=
